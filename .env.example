# Imugi Panel configuration.
# Copy to .env and edit. docker compose reads .env automatically.
#   cp .env.example .env
# Never commit your real .env - it is gitignored.

# --- mieru/mita version ---
# Tag of the mita daemon image (ghcr.io/enfein/mita) used as the Docker base.
# MUST match the mieru module version in go.mod. To bump both safely:
#   scripts/update-mieru.sh v3.35.0
MITA_VERSION=v3.34.0

# --- Panel HTTP server ---
# Port the panel listens on.
PANEL_PORT=8686
# Host IP the panel port is published on. Default 127.0.0.1 (loopback only,
# reach it via a tunnel or reverse proxy). Set to 0.0.0.0 or a specific IP to
# expose it — only behind TLS.
PANEL_BIND_IP=127.0.0.1
# mita proxy port(s). This one value both publishes the ports and sets mita's
# port bindings, so you manage them in one place. The panel re-applies it on
# every start; the Network page is read-only while this is set.
# One port is enough. Examples:
#   PROXY_PORTS=2012            single port
#   PROXY_PORTS=2012-2022       a range (port-hopping)
#   PROXY_PORTS=2012,2020,2027  a mix
PROXY_PORTS=2012
# Two different addresses — don't mix them up:
#
# PUBLIC_HOST — where CLIENT APPS connect (the proxy). Your server's public IP
# or a domain pointing at it, host only, no scheme. Goes into every share link
# and client config. Also settable later under Settings.
# PUBLIC_HOST=203.0.113.10
#
# PANEL_URL — where YOU open this admin panel in a browser (https://host[:port]).
# Used as the base for share links and to validate the Host header (requests to
# any other host are rejected). Leave empty when you reach the panel by IP.
# PANEL_URL=https://vpn.example.com
# Panel domain for the dockerized-nginx setup (docker-compose.nginx.yml only):
# nginx serves TLS for this name and proxies to the panel. Set PANEL_URL too.
# PANEL_DOMAIN=vpn.example.com
# Serve the whole admin panel under a secret prefix (obscurity). Other paths
# return 404. Leave empty for root. Use something unguessable, not "/panel".
# PANEL_BASE_PATH=/a7Fq2xK
# Public prefix for share links, kept separate from the admin path so a shared
# link never reveals it. Default /s.
# SHARE_PATH=/s
# Public prefix for subscription links (permanent, auto-refreshing client
# configs). Must differ from the panel and share paths. Default /sub.
# SUB_PATH=/sub
# Serve subscriptions on a dedicated port with its own listener (the admin
# panel and share pages stay off it). Empty = same port as the panel. A
# dedicated port requires TLS - SUB_TLS_CERT/SUB_TLS_KEY, falling back to
# PANEL_TLS_CERT/PANEL_TLS_KEY - because subscriptions contain user passwords.
# Set SUB_INSECURE_HTTP=1 only when a TLS-terminating reverse proxy fronts it.
# SUB_PORT=8688
# SUB_TLS_CERT=/data/certs/sub.pem
# SUB_TLS_KEY=/data/certs/sub.key
# SUB_INSECURE_HTTP=1
# Bind address (host networking only). In bridge mode the port publish decides
# exposure; leave unset so the container listens on all interfaces internally.
# PANEL_BIND=127.0.0.1

# --- Panel admin (first run only) ---
# If unset, on first start the panel creates user "admin" with a random
# password printed once to the container logs. Change it later under Settings.
# PANEL_ADMIN_USER=admin
# PANEL_ADMIN_PASSWORD=change-me-please

# --- TLS (optional) ---
# Set both to serve HTTPS natively. Otherwise the panel serves plain HTTP and
# warns when accessed over a non-loopback address. Paths are inside the
# container - mount the certs via the /data volume, e.g. /data/tls/cert.pem.
# PANEL_TLS_CERT=/data/tls/cert.pem
# PANEL_TLS_KEY=/data/tls/key.pem
# Behind a TLS-terminating reverse proxy or load balancer, the panel itself
# speaks plain HTTP and would otherwise show a "plain HTTP" warning. Set this
# to true to trust the proxy's X-Forwarded-Proto header and silence it. Enable
# ONLY when such a proxy is actually in front of the panel — otherwise a client
# could forge the header. The bundled nginx compose sets this for you.
# PANEL_TRUST_PROXY=true

# --- Advanced / rarely changed ---
# Where the panel keeps its SQLite DB and state (also a Docker volume).
# PANEL_DATA_DIR=/data
# mita management socket path (must match the mita user's writable dir).
# MITA_UDS_PATH=/var/run/mita/mita.sock
# Override the gRPC target; use tcp://host:port for local dev against a
# socat-bridged mita instead of the default unix://$MITA_UDS_PATH.
# MITA_RPC_TARGET=unix:///var/run/mita/mita.sock
# Path to the mita binary the panel supervises.
# MITA_BINARY=/usr/local/bin/mita
# Directory holding GeoIP datasets (*.dat, xray format). Mount your own .dat
# files here to use them without downloading. Defaults to $PANEL_DATA_DIR/geoip.
# GEOIP_DIR=/data/geoip
# mieru client binary (used for chaining panels). Defaults to /usr/local/bin/mieru.
# MIERU_BINARY=/usr/local/bin/mieru

# --- Metrics (OpenTelemetry, optional) ---
# mieru releases; the compose image tag. Defaults to latest.
# IMUGI_PANEL_TAG=latest
#
# Push metrics over OTLP by setting the standard OTEL variables. Example for
# OpenObserve (reads them directly, no collector needed):
# OTEL_EXPORTER_OTLP_ENDPOINT=https://openobserve.example.com/api/default
# OTEL_EXPORTER_OTLP_HEADERS=Authorization=Basic <base64(user:token)>
# OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
# Or expose a Prometheus scrape endpoint at /metrics:
# PANEL_METRICS_PROMETHEUS=true
